# DEMO / DESARROLLO LOCAL
# Sin Supabase, permite login demo vía cookie firmada (útil para tests e2e y prototipos).
AUTH_DEMO_MODE=true
# Expuesto al cliente solo como flag; no sustituye el secreto de firma (NEXTAUTH_SECRET).
NEXT_PUBLIC_AUTH_DEMO_MODE=true
DEMO_EMAIL=demo@normaflow.io
DEMO_PASSWORD=NormaFlow2025!
DEMO_SESSION_SECRET=opcional-si-no-usas-NEXTAUTH_SECRET
